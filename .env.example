# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# App
NEXT_PUBLIC_SITE_URL=https://www.srinathayogaschool.com
NEXT_PUBLIC_APP_URL=https://www.srinathayogaschool.com

# Google OAuth (optional)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Resend (for Supabase Custom SMTP)
RESEND_API_KEY=your_resend_api_key_here

# Google Analytics (optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Vercel (deployment tokens — do not commit)
VERCEL_TOKEN=
VERCEL_API_TOKEN=

# GitHub (API token — do not commit)
GITHUB_TOKEN=

# Supabase Personal Access Token (for project management API — do not commit)
SUPABASE_ACCESS_TOKEN=

# Stream (if using Livepeer/Stream)
STREAM_ID=
STREAM_URL=
